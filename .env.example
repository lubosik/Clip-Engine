# Clip Engine — environment variables
# Copy to .env for local development. Never commit .env.

# Apify API token — required for all Apify actor calls (discovery, transcripts, comments)
APIFY_TOKEN=

# Postgres connection string — required for all DB operations
DATABASE_URL=

# Postiz self-hosted instance — required for scheduling
POSTIZ_API_URL=
POSTIZ_API_KEY=

# LLM (Anthropic Messages API) — required for clip ranking
LLM_API_KEY=
LLM_MODEL=claude-3-5-haiku-20241022

# Absolute path to clip/asset storage volume (default: /data/clips)
STORAGE_DIR=/data/clips

# Simple bearer password for the review PWA — required when running web
WEB_ADMIN_PASSWORD=

# Timezone (affects scheduling logic)
TZ=America/New_York

# ---------------------------------------------------------------------------
# Cloudflare R2 — S3-compatible object storage (optional; enables R2 mode)
# Account: ff595249c8042ae47c68bafe4be405dc
# R2_ENDPOINT is non-secret (account-specific subdomain of cloudflarestorage.com)
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://ff595249c8042ae47c68bafe4be405dc.r2.cloudflarestorage.com

# ---------------------------------------------------------------------------
# Modal serverless GPU rendering (optional; enables cloud render path)
# Obtain tokens from: modal.com → Settings → API Tokens
# RENDER_BACKEND: auto (default) | modal | local
# MODAL_MONTHLY_BUDGET: operator warning cap in USD (default 30)
# ---------------------------------------------------------------------------
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
RENDER_BACKEND=auto
MODAL_MONTHLY_BUDGET=30

# Meme image generation model (via LLM_BASE_URL provider or direct API)
MEME_IMAGE_MODEL=

# --- Clip quality pass (2026-07-12) ---
# Boundary verification model override (default: anthropic/claude-haiku-4.5, then LLM_MODEL)
BOUNDARY_CHECK_MODEL=

# Enable LR-ASD active speaker detection in the Modal render container
# (0 = off, default; 1 = on — requires weights baked at LRASD_WEIGHTS_PATH)
REFRAME_ASD=0

# Path to LR-ASD weights inside the Modal container (only read when REFRAME_ASD=1)
# LRASD_WEIGHTS_PATH=/models/lrasd/weight/finetuning_AVA.model
